@model SportsStore.Models.Order

<h2>Checkout</h2>
<p class="text-muted">Please enter your shipping details. You will be redirected to Stripe to complete payment securely.</p>

<form method="post" asp-action="Checkout">
    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

    <h4 class="mt-3">Shipping Details</h4>
    <div class="mb-3">
        <label asp-for="Name" class="form-label">Full Name</label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Line1" class="form-label">Address Line 1</label>
        <input asp-for="Line1" class="form-control" />
        <span asp-validation-for="Line1" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Line2" class="form-label">Address Line 2 (optional)</label>
        <input asp-for="Line2" class="form-control" />
    </div>
    <div class="row">
        <div class="col mb-3">
            <label asp-for="City" class="form-label">City</label>
            <input asp-for="City" class="form-control" />
            <span asp-validation-for="City" class="text-danger"></span>
        </div>
        <div class="col mb-3">
            <label asp-for="State" class="form-label">State / County (optional)</label>
            <input asp-for="State" class="form-control" />
        </div>
    </div>
    <div class="row">
        <div class="col mb-3">
            <label asp-for="Zip" class="form-label">Postal Code</label>
            <input asp-for="Zip" class="form-control" />
            <span asp-validation-for="Zip" class="text-danger"></span>
        </div>
        <div class="col mb-3">
            <label asp-for="Country" class="form-label">Country</label>
            <input asp-for="Country" class="form-control" />
            <span asp-validation-for="Country" class="text-danger"></span>
        </div>
    </div>

    <div class="form-check mb-3">
        <input asp-for="GiftWrap" class="form-check-input" type="checkbox" />
        <label asp-for="GiftWrap" class="form-check-label">Gift wrap this order</label>
    </div>

    <div class="d-flex justify-content-between mt-3">
        <a href="/Cart" class="btn btn-outline-secondary">Back to Cart</a>
        <button type="submit" class="btn btn-primary">Pay with Stripe</button>
    </div>
</form>
