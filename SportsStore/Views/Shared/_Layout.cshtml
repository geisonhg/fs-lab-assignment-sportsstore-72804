<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>SportsStore</title>
    <link href="/lib/bootstrap/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body {
            background-color: #f8f9fa;
            font-family: 'Segoe UI', system-ui, sans-serif;
        }
        .ss-navbar {
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 60%, #0f3460 100%);
            padding: 0.75rem 1.5rem;
            box-shadow: 0 2px 8px rgba(0,0,0,0.3);
        }
        .ss-brand {
            font-size: 1.4rem;
            font-weight: 700;
            letter-spacing: 2px;
            color: #fff;
            text-decoration: none;
        }
        .ss-brand span { color: #e94560; }
        .ss-cart-btn {
            background: #e94560;
            border: none;
            color: #fff;
            padding: 0.4rem 1.1rem;
            border-radius: 20px;
            font-size: 0.85rem;
            font-weight: 600;
            text-decoration: none;
            transition: background 0.2s;
        }
        .ss-cart-btn:hover { background: #c73652; color: #fff; }
        .ss-main { max-width: 1100px; margin: 0 auto; padding: 2rem 1rem; }
        .product-card {
            border: none;
            border-radius: 12px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.08);
            transition: transform 0.2s, box-shadow 0.2s;
            background: #fff;
            height: 100%;
        }
        .product-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 24px rgba(0,0,0,0.13);
        }
        .product-card .card-header {
            background: #f0f4ff;
            border-radius: 12px 12px 0 0;
            border-bottom: 1px solid #e3e8f0;
            padding: 1rem 1.2rem 0.6rem;
        }
        .product-price {
            background: #e94560;
            color: #fff;
            border-radius: 20px;
            padding: 0.2rem 0.7rem;
            font-size: 0.9rem;
            font-weight: 700;
        }
        .product-name { font-size: 1.05rem; font-weight: 600; color: #1a1a2e; margin: 0; }
        .product-description { color: #6c757d; font-size: 0.88rem; line-height: 1.5; }
        .btn-add-cart {
            background: #0f3460;
            color: #fff;
            border: none;
            border-radius: 8px;
            font-size: 0.85rem;
            font-weight: 600;
            padding: 0.4rem 1rem;
            transition: background 0.2s;
            width: 100%;
        }
        .btn-add-cart:hover { background: #e94560; color: #fff; }
        .ss-section-title {
            font-size: 1.5rem;
            font-weight: 700;
            color: #1a1a2e;
            margin-bottom: 1.5rem;
            padding-bottom: 0.5rem;
            border-bottom: 3px solid #e94560;
            display: inline-block;
        }
        .ss-page-btn {
            display: inline-block;
            margin: 0 3px;
            padding: 0.4rem 0.9rem;
            border-radius: 8px;
            font-size: 0.85rem;
            font-weight: 600;
            text-decoration: none;
            border: 2px solid #0f3460;
            color: #0f3460;
            transition: all 0.2s;
        }
        .ss-page-btn:hover, .ss-page-btn.btn-primary {
            background: #0f3460;
            color: #fff;
        }
    </style>
</head>
<body>
    <nav class="ss-navbar d-flex justify-content-between align-items-center">
        <a href="/" class="ss-brand">SPORTS<span>STORE</span></a>
        <a href="/Cart" class="ss-cart-btn">&#128722; Cart</a>
    </nav>

    <div class="ss-main">
        @RenderBody()
    </div>

    <footer class="text-center text-muted py-4 mt-4" style="font-size:0.8rem;border-top:1px solid #dee2e6;">
        &copy; @DateTime.Now.Year SportsStore &mdash; Secure payments by Stripe
    </footer>
</body>
</html>
