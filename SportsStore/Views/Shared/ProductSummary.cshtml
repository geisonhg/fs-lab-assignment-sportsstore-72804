@model Product

<div class="product-card card d-flex flex-column">
    <div class="card-header d-flex justify-content-between align-items-start">
        <p class="product-name">@Model?.Name</p>
        <span class="product-price ms-2">@Model?.Price.ToString("c")</span>
    </div>
    <div class="card-body d-flex flex-column">
        <p class="product-description flex-grow-1">@Model?.Description</p>
        <form method="post" asp-controller="Cart" asp-action="AddToCart" class="mt-2">
            <input type="hidden" name="productId" value="@Model?.ProductID" />
            <button type="submit" class="btn-add-cart">+ Add to Cart</button>
        </form>
    </div>
</div>
